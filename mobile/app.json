{
  "expo": {
    "name": "언블라인드",
    "slug": "unblind",
    "version": "0.1.0",
    "orientation": "portrait",
    "platforms": ["ios", "android"],
    "icon": "./assets/images/unblind-logo.png",
    "scheme": "unblind",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "kr.unblind.app",
      "supportsTablet": false,
      "icon": "./assets/images/unblind-logo.png",
      "infoPlist": {
        "CFBundleDisplayName": "언블라인드"
      }
    },
    "android": {
      "package": "kr.unblind.app",
      "adaptiveIcon": {
        "backgroundColor": "#FF4B22",
        "foregroundImage": "./assets/images/unblind-logo.png"
      },
      "predictiveBackGestureEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FF4B22",
          "image": "./assets/images/unblind-logo.png",
          "imageWidth": 180
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
