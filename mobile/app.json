{
  "expo": {
    "name": "언블라인드",
    "slug": "unblind",
    "version": "0.2.0",
    "orientation": "portrait",
    "platforms": ["ios", "android"],
    "icon": "./assets/brand/unblind-mark-glass.png",
    "scheme": "unblind",
    "userInterfaceStyle": "automatic",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "bundleIdentifier": "kr.unblind.app",
      "buildNumber": "1",
      "supportsTablet": false,
      "icon": "./assets/brand/unblind-mark-glass.png",
      "entitlements": {
        "aps-environment": "development"
      },
      "infoPlist": {
        "CFBundleDisplayName": "언블라인드",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "kr.unblind.app",
      "adaptiveIcon": {
        "backgroundColor": "#FF4B22",
        "foregroundImage": "./assets/brand/unblind-mark-glass.png"
      },
      "predictiveBackGestureEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-updates",
      [
        "expo-notifications",
        {
          "color": "#FF4B22"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FF4B22",
          "image": "./assets/brand/unblind-mark-glass.png",
          "imageWidth": 180
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
